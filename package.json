{
  "name": "rdqa-extension",
  "displayName": "RDQA",
  "version": "1",
  "description": "Automated QA extension",
  "author": "REDSTONE | Demov Serhii",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "plasmo build",
    "package": "plasmo package",
    "agent": "node qa-agent/server.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/modifiers": "9.0.0",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@tiptap/extension-link": "3.23.1",
    "@tiptap/extension-text-align": "3.23.1",
    "@tiptap/react": "3.23.1",
    "@tiptap/starter-kit": "3.23.1",
    "highlight.js": "^11.11.1",
    "jszip": "^3.10.1",
    "lucide-react": "1.14.0",
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "tailwind-merge": "3.6.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "autoprefixer": "10.5.0",
    "postcss": "8.5.14",
    "prettier": "3.2.4",
    "tailwindcss": "^3.4.19",
    "typescript": "5.3.3"
  },
  "manifest": {
    "host_permissions": [
      "http://127.0.0.1/*",
      "http://localhost/*"
    ],
    "permissions": [
      "activeTab",
      "scripting",
      "storage",
      "tabs",
      "downloads",
      "tabCapture"
    ]
  }
}
